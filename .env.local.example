# Supabase — create a project at https://supabase.com/dashboard, then copy
# the values from Project Settings → API into .env.local (never commit it).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Public site URL (used for JSON-LD / metadata / sitemap / robots / reset links).
# Local dev: keep http://localhost:3000
# Production: set to https://www.linawdinig.com in your host's env vars.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend transactional email — https://resend.com
# API key from Resend → API Keys.
RESEND_API_KEY=re_...
# Verified sender. The domain (linawdinig.com) must be verified in Resend.
EMAIL_FROM=Linaw Dinig Hearing Aid Center <noreply@linawdinig.com>
# Inbox(es) that receive new booking/contact form submissions.
# Separate multiple recipients with commas, e.g. a@x.com,b@y.com,c@z.com
CONTACT_NOTIFY_EMAIL=linaw.dinig.hac@gmail.com
