# Supabase — create a project at https://supabase.com/dashboard, then copy
# the values from Project Settings → API into .env.local (never commit it).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Public site URL (used for JSON-LD / metadata / sitemap / robots).
# Local dev: keep http://localhost:3000
# Production: set to https://www.linawdinig.com in your host's env vars.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
